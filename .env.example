# Copy this file to .env.local and fill in your real values
# Run: cp .env.example .env.local

# ── MongoDB ──────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/payslip?retryWrites=true&w=majority

# ── NextAuth ─────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-random-secret-here
# Change to your Vercel URL after deploying
NEXTAUTH_URL=http://localhost:3000

# ── Stellar (no keys needed — public testnet) ────────────
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_HORIZON=https://horizon-testnet.stellar.org

# ── Firebase (for TrustCert — optional for PaySlip) ──────
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# ── Email (optional — for invite emails) ─────────────────
RESEND_API_KEY=re_your_key_here